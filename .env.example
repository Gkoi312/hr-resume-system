# 数据库连接（复制为 .env 并修改密码）
# 使用 PostgreSQL 默认用户 postgres，数据库 hr_resume
# 首次使用需在 PostgreSQL 中创建数据库：createdb -U postgres hr_resume
# 或 psql -U postgres -c "CREATE DATABASE hr_resume;"
DATABASE_URL=postgresql+asyncpg://postgres:你的密码@localhost:5432/hr_resume

# HR 登录 JWT（生产环境务必设置强随机 JWT_SECRET）
# JWT_SECRET=
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------------------------------------------------------------------------
# 推荐按“模式”配置（if/else）：
#
# IF 仅用 Paddle + 规则（最低成本）
#   RESUME_LLM_ENABLED=0
#   RESUME_LLM_VISION=0
#   RESUME_VLLM_ENABLED=0
#   RESUME_PADDLE_ENABLED=1
#
# ELSE IF Paddle + 文本 LLM（当前默认推荐）
#   RESUME_LLM_ENABLED=1
#   RESUME_LLM_VISION=0
#   RESUME_VLLM_ENABLED=0
#   RESUME_PADDLE_ENABLED=1
#
# ELSE IF 视觉 LLM(vLLM) 直抽 simple JSON（可关闭 Paddle）
#   RESUME_LLM_ENABLED=0            # 文本 LLM 关闭也可
#   RESUME_LLM_VISION=1             # 或 RESUME_VLLM_ENABLED=1
#   RESUME_VLLM_ENABLED=1
#   RESUME_PADDLE_ENABLED=0         # 可选；开着也没问题，失败时可回退
# ---------------------------------------------------------------------------

# 文本 LLM（simple JSON, 非视觉）- 前缀 RESUME_LLM_
# （app/llm/chat_client.ChatLLMClient 无参时默认亦使用此前缀；JD 抽取等为 JOB_LLM_ 等）
# RESUME_LLM_ENABLED=1
# RESUME_LLM_PROVIDER=openai_compatible
# RESUME_LLM_API_KEY=你的DashScope_API_Key
# RESUME_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# RESUME_LLM_MODEL=qwen-plus
# RESUME_LLM_TEMPERATURE=0.2
# RESUME_LLM_MAX_TOKENS=4096
# RESUME_LLM_TIMEOUT_SECONDS=120

# Job JD 抽取 LLM（/jobs/upload 结构化提取）- 前缀 JOB_LLM_
# JOB_LLM_ENABLED=0                # 1 开启；0 关闭（关闭时上传会报 LLM_FAILED）
# JOB_LLM_PROVIDER=openai_compatible
# JOB_LLM_API_KEY=你的DashScope_API_Key
# JOB_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# JOB_LLM_MODEL=qwen-plus
# JOB_LLM_TEMPERATURE=0.2
# JOB_LLM_MAX_TOKENS=4096
# JOB_LLM_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# Paddle PP-Structure V3（PDF/图片默认路径，不启用视觉 LLM 时使用）
# RESUME_PADDLE_ENABLED=1   # 0 关闭（PDF/图将无法解析，除非开启下方视觉 LLM）
# RESUME_PADDLE_DEVICE=cpu # 或 gpu
#
# 解析阶段减少 PaddleX 联网检查与控制台噪音（ccache / requests 版本等 UserWarning，以及 paddlex INFO）：
# RESUME_PADDLE_QUIET=1     # 默认等价于开启；设为 0/false/off 可恢复详细日志与警告
# 代码会在首次使用 Paddle 前设置（与手动设置等效）：
# PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
# DISABLE_MODEL_SOURCE_CHECK=True
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# （可选）视觉 LLM(vLLM)：
# 两种写法二选一：
# 1) 复用 RESUME_LLM_* 配置：只开 RESUME_LLM_VISION=1
# 2) 单独配置视觉模型：开 RESUME_VLLM_ENABLED=1 并设置 RESUME_VLLM_*
# ---------------------------------------------------------------------------
# RESUME_LLM_VISION=1
# RESUME_LLM_VISION_MAX_PAGES=2
# RESUME_LLM_VISION_DPI=150

# RESUME_VLLM_ENABLED=1
# RESUME_VLLM_PROVIDER=openai_compatible
# RESUME_VLLM_API_KEY=你的Vision模型Key
# RESUME_VLLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# RESUME_VLLM_MODEL=qwen-vl-max
# RESUME_VLLM_TEMPERATURE=0.2
# RESUME_VLLM_MAX_TOKENS=4096
# RESUME_VLLM_TIMEOUT_SECONDS=120
#
# 其它 OpenAI 兼容服务示例（任选其一，勿与上面同时混用未改 BASE_URL）：
# RESUME_LLM_BASE_URL=https://api.openai.com/v1
# RESUME_LLM_MODEL=gpt-4.1-mini

# ---------------------------------------------------------------------------
# Embedding（三选一）
#
# A) 本机 Ollama（默认安装地址，无需 HuggingFace 再下一份权重）
#    API: POST http://127.0.0.1:11434/api/embeddings  （见 Ollama 文档 api.md）
#    模型名与 ollama list 一致，例如 bge-m3；维度须与 pgvector 列一致（bge-m3 多为 1024）
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL_NAME=bge-m3
# EMBEDDING_DIM=1024
# OLLAMA_EMBED_BASE_URL=http://127.0.0.1:11434
# OLLAMA_EMBED_TIMEOUT_SECONDS=180
# 超长输入时开启截断（与 Ollama /api/embed 一致）
# OLLAMA_EMBED_TRUNCATE=true
# 仅当需走系统代理访问 Ollama 时设为 true（默认 false，避免本机 11434 被代理成 502）
# OLLAMA_HTTP_TRUST_ENV=false
# VPN 场景下可与系统「绕过代理」一致；dotenv 加载后写入进程环境
# NO_PROXY=127.0.0.1,localhost
#
# B) BGE via SentenceTransformers（从 HuggingFace 首次自动拉模型）
# EMBEDDING_PROVIDER=bge
# EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
# EMBEDDING_DIM=384
#
# C) debug 伪向量（无外部服务；须与 EMBEDDING_DIM / 库列一致）
# EMBEDDING_PROVIDER=debug
# EMBEDDING_DIM=384
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Vector store backend
# - db: current DB-backed JSON vectors (earlier implementation)
# - pgvector: use pgvector + cosine distance (in the later plan)
# ---------------------------------------------------------------------------
VECTOR_STORE_BACKEND=pgvector


